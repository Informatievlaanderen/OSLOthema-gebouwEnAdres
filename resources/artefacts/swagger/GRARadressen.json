{
  "openapi": "3.0.4",
  "info": {
    "title": "GRAR Adres REST",
    "description": "GRAR OSLO-conforme REST API voor adressen",
    "version": "3.0.0"
  },
  "servers": [
    {
      "url": "https://implementatie.data.test-vlaanderen.be/",
      "description": "Basis URL"
    }
  ],
  "paths": {
    "/v3/adressen/{id}": {
      "get": {
        "summary": "De collectie van de uitgewisselde adressen en metadata elementen.",
        "operationId": "adressenGET",
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "description": "Nulgebaseerde index van de eerste instantie die teruggegeven wordt. De offset is echter beperkt tot 1000000, indien meer data dient ingelezen te worden is het gebruik van extra filters aangewezen op de service of verwijzen we naar de <a href=\"https://basisregisters.vlaanderen.be/producten/grar\" target=\"_blank\">downloadproducten van het gebouwen- en adressenregister</a> (optioneel).",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Aantal instanties dat teruggegeven wordt. Maximaal kunnen er 500 worden teruggegeven. Wanneer limit niet wordt meegegeven dan default 100 instanties (optioneel).",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "gemeentenaam",
            "in": "query",
            "description": "Filter op de gemeentenaam van het adres (exact) (optioneel).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "postcode",
            "in": "query",
            "description": "Filter op de postcode van het adres (exact) (optioneel).",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "straatnaam",
            "in": "query",
            "description": "Filter op de straatnaam van het adres (exact) (optioneel).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "homoniemToevoeging",
            "in": "query",
            "description": "Filter op de homoniemtoevoeging van het adres (exact) (optioneel).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "huisnummer",
            "in": "query",
            "description": "Filter op het huisnummer van het adres (exact) (optioneel).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "busnummer",
            "in": "query",
            "description": "Filter op het busnummer van het adres (exact) (optioneel).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "niscode",
            "in": "query",
            "description": "Filter op de NIS-code van het adres (exact) (optioneel).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter op de status van het adres (exact) (optioneel). \\\n`\"voorgesteld\"` `\"inGebruik\"` `\"gehistoreerd\"` `\"afgekeurd\"`",
            "schema": {
              "type": "string",
              "pattern": "^https:\\/\\/data\\.vlaanderen\\.be\\/id\\/organisatie\\/OVO\\d{6}$"
            },
 
            "examples":{
                "voorgesteld":{
                    "summary": "Voorgesteld",
                    "value":"TODO URI"
                }
            }
          },
          {
            "name": "straatnaamObjectId",
            "in": "query",
            "description": "Filter op de objectidentificator van de gekoppelde straatnaam (exact) (optioneel).",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "if-None-Match",
            "in": "header",
            "description": "If-None-Match header met ETag van een vorig verzoek (optioneel).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "description": "x-api-key header met verkregen API key (optioneel).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "adressen object gevonden.",
            "content": {
              "application/ld+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/DataEnvelop"
                }
              }
            
            }
          },
          "400": {
            "description": "Invalid data supplied.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            },
            "links": {
              "Probleemdetail.type": {
                "operationId": "adressenGET",
                "parameters": {
                  "type": "$response.body#/type"
                },
                "description": "De waarde van het attribuut `type` kan gebruikt worden om het gerefereerde object van het type `ProblemDetails` op te halen."
              }
            }
          },
          "403": {
            "description": "Authentication failed.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            },
            "links": {
              "Probleemdetail.type": {
                "operationId": "adressenGET",
                "parameters": {
                  "type": "$response.body#/type"
                },
                "description": "De waarde van het attribuut `type` kan gebruikt worden om het gerefereerde object van het type `ProblemDetails` op te halen."
              }
            }
          },
          "406": {
            "description": "Not acceptable.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            },
            "links": {
              "Probleemdetail.type": {
                "operationId": "adressenGET",
                "parameters": {
                  "type": "$response.body#/type"
                },
                "description": "De waarde van het attribuut `type` kan gebruikt worden om het gerefereerde object van het type `ProblemDetails` op te halen."
              }
            }
          },
          "429": {
            "description": "Too many requests.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            },
            "links": {
              "Probleemdetail.type": {
                "operationId": "adressenGET",
                "parameters": {
                  "type": "$response.body#/type"
                },
                "description": "De waarde van het attribuut `type` kan gebruikt worden om het gerefereerde object van het type `ProblemDetails` op te halen."
              }
            }
          },
          "500": {
            "description": "Unexpected Server Error.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            },
            "links": {
              "Probleemdetail.type": {
                "operationId": "adressenGET",
                "parameters": {
                  "type": "$response.body#/type"
                },
                "description": "De waarde van het attribuut `type` kan gebruikt worden om het gerefereerde object van het type `ProblemDetails` op te halen."
              }
            }
          }
          
        }
      }
    }
  },
