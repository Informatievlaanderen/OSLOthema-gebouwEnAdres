{
  "openapi": "3.0.4",
  "info": {
    "title": "GRAR Gemeente REST",
    "description": "GRAR OSLO-conforme REST API voor gemeenten",
    "version": "3.0.0"
  },
  "servers": [
    {
      "url": "https://implementatie.data.test-vlaanderen.be/",
      "description": "Basis URL"
    }
  ],
  "paths": {
    "/v3/gemeenten/{objectId}": {
      "get": {
        "tags": [
          "Gemeenten"
        ],
        "summary": "Vraag een gemeente op (v3).",
        "operationId": "GetMunicipalityV3",
        "parameters": [
          {
            "name": "objectId",
            "in": "path",
            "description": "Identificator van de gemeente.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            },
            "examples": {
              "Gent": {
                "summary": "Stad Gent",
                "value": "44021"
              },
              "Antwerpen": {
                "summary": "Stad Antwerpen",
                "value": "11002"
              },
              "Kortrijk": {
                "summary": "Stad Kortrijk",
                "value": "34000"
              },
              "Hasselt1": {
                "summary": "Stad Hasselt (tot 2024)",
                "value": "71022"
              },
              "Hasselt2": {
                "summary": "Stad Hasselt (vanaf 2025)",
                "value": "71072"
              }
            }
          },
          {
            "name": "If-None-Match",
            "in": "header",
            "description": "If-None-Match header met ETag van een vorig verzoek (optioneel).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Api-Key",
            "in": "header",
            "description": "X-Api-Key header met verkregen API key (optioneel).",
            "schema": {
              "type": "string"
            }
          }
        ],

        "responses": {
          "200": {
            "description": "Als de gemeente gevonden is.",
            "content": {
              "application/ld+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/GemeenteEnvelop"
                }
              }
            
            }
          },
          "304": {
            "description": "Als het gemeente niet gewijzigd is ten opzicht van uw verzoek.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            }
          },
          "400": {
            "description": "Als uw verzoek foutieve data bevat.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            }
          },
          "403": {
            "description": "Als u niet beschikt over de correcte rechten om deze actie uit te voeren.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            }
          },
          "404": {
            "description": "Als de gemeente niet gevonden kan worden.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            }
          },
          "406": {
            "description": "Als het gevraagde formaat niet beschikbaar is.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            }
          },
          "429": {
            "description": "Als het aantal requests per seconde de limiet overschreven heeft.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            }
          },
          "500": {
            "description": "Als er een interne fout is opgetreden.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            }
          }     
        }
      }
    }
  }
}