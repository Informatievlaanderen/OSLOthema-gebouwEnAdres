{
  "openapi": "3.0.4",
  "info": {
    "title": "GRAR Postinfo REST",
    "description": "GRAR OSLO-conforme REST API voor postinfo",
    "version": "3.0.0"
  },
  "servers": [
    {
      "url": "https://implementatie.data.test-vlaanderen.be/",
      "description": "Basis URL"
    }
  ],
  "paths": {
    "/v3/postinfo/{objectId}": {
      "get": {
        "tags": [
           "Postinfo"
        ],
        "summary": "Vraag postinfo voor een postcode op (v3).",
        "operationId": "GetPostalCodeV3",
        "parameters": [
          {
            "name": "objectId",
            "in": "path",
            "description": "Identificator van de postinfo.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "examples": {
              "Gent": {
                "summary": "Stad Gent",
                "value": "9000"
              },
              "Antwerpen": {
                "summary": "Stad Antwerpen",
                "value": "2000"
              },
              "Kortrijk": {
                "summary": "Stad Kortrijk",
                "value": "8500"
              },
              "Hasselt": {
                "summary": "Stad Hasselt",
                "value": "3500"
              }
            }
          },
          {
            "name": "If-None-Match",
            "in": "header",
            "description": "If-None-Match header met ETag van een vorig verzoek (optioneel).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Api-Key",
            "in": "header",
            "description": "X-Api-Key header met verkregen API key (optioneel).",
            "schema": {
              "type": "string"
            }
          }
        ],

        "responses": {
          "200": {
            "description": "Als de postinfo voor een postcode gevonden is.",
            "content": {
              "application/ld+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/PostinfoEnvelop"
                }
              }
            
            }
          },
          "304": {
            "description": "Als de postinfo voor een postcode niet gewijzigd is ten opzicht van uw verzoek.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            }
          },
          "400": {
            "description": "Als uw verzoek foutieve data bevat.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            }
          },
          "403": {
            "description": "Als u niet beschikt over de correcte rechten om deze actie uit te voeren.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            }
          },
          "404": {
            "description": "Als de postinfo voor een postcode niet gevonden kan worden.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            }
          },
          "406": {
            "description": "Als het gevraagde formaat niet beschikbaar is.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            }
          },
          "429": {
            "description": "Als het aantal requests per seconde de limiet overschreven heeft.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            }
          },
          "500": {
            "description": "Als er een interne fout is opgetreden.",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "components.json#/components/schemas/Probleemdetail"
                }
              }
            }
          }
        }
      }
    }
  }
}